{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "League Timer",
  "version": "0.1.0",
  "identifier": "com.jon.league-timer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "League Timer",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 500
      },
      {
        "label": "overlay",
        "title": "League Timer Overlay",
        "url": "/?overlay=1",
        "width": 420,
        "height": 320,
        "alwaysOnTop": true,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
