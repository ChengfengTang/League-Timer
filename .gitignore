# Data & model artifacts (large, not source)
data/*
models/*
*.zip
!**/.gitkeep

# Inference outputs
outputs/

# Champion-specific tuning (copy configs/example.yaml locally, then tune)
configs/*.yaml
!configs/example.yaml

# Name + level OCR templates (capture per champion / resolution)
configs/templates/*
!configs/templates/.gitkeep

# Local caches (torch hub weights, pycache prefix, etc.)
.torchhome/
.cache/
.pycache/
*.mp4
*.mkv
*.mov
!data/**/.gitkeep

# Rust / Tauri build output
src-tauri/target/

# Python
__pycache__/
*.py[cod]
.venv/
venv/
env/
*.egg-info/
.ipynb_checkpoints/

# OS / editor
.DS_Store
.idea/
.vscode/
